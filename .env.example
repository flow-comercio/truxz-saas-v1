# ─── Banco de Dados ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://truxz:Win7830@@localhost:5432/truxz_db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="truxz-secret-Win7830@-production-key-2024"
NEXTAUTH_URL="https://truxz.com.br"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://truxz.com.br"
NODE_ENV="production"

# ─── Asaas (Pagamentos) ──────────────────────────────────────────────────────
# Obtenha em: https://app.asaas.com/apiTokens
ASAAS_API_KEY=""
ASAAS_WEBHOOK_SECRET=""
ASAAS_ENV="production"   # ou "sandbox" para testes

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Para Gmail: ative "App passwords" e use como SMTP_PASS
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@gmail.com"
SMTP_PASS="sua-app-password"

# ─── Upload ──────────────────────────────────────────────────────────────────
UPLOAD_DIR="/var/www/truxz/uploads"
MAX_FILE_SIZE="5242880"

# ─── Subdomínio dinâmico ─────────────────────────────────────────────────────
# Domínio base do sistema (lojas ficam em nomeLoja.truxz.com.br)
BASE_DOMAIN="truxz.com.br"
